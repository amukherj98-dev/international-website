MONGODB_URI=mongodb://127.0.0.1:27017/ie-students
PORT=5000
JWT_SECRET=change-this-to-a-long-random-string
NEWS_API_KEY=
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!
CLIENT_ORIGIN=http://localhost:5173

# Optional: email the admin when new feedback/submissions come in.
# GMAIL_APP_PASSWORD is a Google "App Password", not your regular Gmail password -
# generate one at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
GMAIL_USER=
GMAIL_APP_PASSWORD=
ADMIN_NOTIFICATION_EMAIL=
PUBLIC_APP_URL=http://localhost:5173

# Optional: auto-sync gallery photos from a private Google Drive folder.
# Share the folder (Viewer) with your service account's email - never make it
# public. Provide the key EITHER as the raw JSON in GOOGLE_SERVICE_ACCOUNT_KEY
# (recommended for hosts with no persistent disk, e.g. Render) OR as a path to
# a local key file in GOOGLE_SERVICE_ACCOUNT_KEY_PATH - never commit the key file itself.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
